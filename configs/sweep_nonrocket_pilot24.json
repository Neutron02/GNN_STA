{
  "platform": "nangate45",
  "openroad_bin": "OpenROAD-flow-scripts/tools/install/OpenROAD/bin/openroad",
  "orfs_flow_dir": "OpenROAD-flow-scripts/flow",
  "liberty": "OpenROAD-flow-scripts/flow/platforms/nangate45/lib/NangateOpenCellLibrary_typical.lib",
  "template_sdc": {
    "dynamic_node": "OpenROAD-flow-scripts/flow/designs/nangate45/dynamic_node/constraint.sdc",
    "ibex": "OpenROAD-flow-scripts/flow/designs/nangate45/ibex/constraint.sdc",
    "jpeg": "OpenROAD-flow-scripts/flow/designs/nangate45/jpeg/constraint.sdc",
    "swerv": "OpenROAD-flow-scripts/flow/designs/nangate45/swerv/constraint.sdc",
    "bp_fe_top": "OpenROAD-flow-scripts/flow/designs/nangate45/bp_fe_top/constraint.sdc",
    "bp_be_top": "OpenROAD-flow-scripts/flow/designs/nangate45/bp_be_top/constraint.sdc"
  },
  "generated_sdc_dir": "configs/sdc_generated",
