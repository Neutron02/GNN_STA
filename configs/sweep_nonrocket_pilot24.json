      "ibex": {
        "base_clock_period_ns": 2.2
      },
      "jpeg": {
        "base_clock_period_ns": 1.0
      },
      "swerv": {
        "base_clock_period_ns": 2.0
      },
      "bp_fe_top": {
        "base_clock_period_ns": 1.8,
        "flow_design": "bp_fe"
      },
      "bp_be_top": {
        "base_clock_period_ns": 2.6,
        "flow_design": "bp_be"
      }
    }
  }
}
